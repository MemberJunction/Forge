{
  "name": "mj-forge",
  "version": "0.5.0",
  "description": "AI-native SQL Server IDE for macOS and Windows",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:stream": "turbo run build --log-order=stream",
    "dev": "npm run build && concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "npm run start --workspace=@mj-forge/renderer",
    "dev:main": "wait-on http://localhost:4200 && unset ELECTRON_RUN_AS_NODE && NODE_ENV=development npm run start --workspace=@mj-forge/main",
    "dev:isolated": "MJDEV_WORKSPACE_DIR=\"$HOME/MJDev-dev\" MJDEV_CONFIG_DIR=\"$HOME/.mjdev-dev\" MJDEV_CONTAINER_PREFIX=mjdev-dev MJDEV_MJ_SOURCE=\"$HOME/MJDev/repos/mj\" npm run dev",
    "start": "turbo run start",
    "watch": "turbo run watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest watch --config vitest.integration.config.ts",
    "test:harness:up": "node tests/scripts/ensure-ssh-key.mjs && docker compose -f tests/docker-compose.test.yml up -d --wait",
    "test:harness:down": "docker compose -f tests/docker-compose.test.yml down -v",
    "test:harness:status": "docker compose -f tests/docker-compose.test.yml ps",
    "test:full": "node tests/reporter/build-report.mjs",
    "test:dashboard": "node tests/reporter/serve.mjs",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --project=e2e --ui",
    "test:e2e:live": "FORGE_LIVE_REPORTER_URL=http://127.0.0.1:5188/_event playwright test --project=e2e",
    "test:visual": "playwright test --project=visual",
    "test:visual:live": "FORGE_LIVE_REPORTER_URL=http://127.0.0.1:5188/_event playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,scss,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,scss,css,html}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "package": "npm run build && node scripts/package.js",
    "package:mac": "npm run build && node scripts/package.js --mac",
    "package:dir": "npm run build && node scripts/package.js --dir",
    "prepare": "husky"
  },
  "main": "packages/main/dist/index.js",
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@memberjunction/sqlglot-ts": "^5.23.0",
    "devicon": "^2.17.0",
    "dockerode": "^4.0.2",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@playwright/test": "^1.58.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "26.4.0",
    "esbuild": "^0.27.7",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.1",
    "syncpack": "^12.3.2",
    "turbo": "^2.3.3",
    "typescript": "~5.4.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "@types/node": "^20.14.2",
    "typescript": "~5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,scss,css,html}": [
      "prettier --write"
    ]
  }
}
