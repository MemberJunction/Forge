{
  "name": "mj-forge",
  "version": "0.0.1",
  "description": "SQL Server database management for macOS",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:stream": "turbo run build --log-order=stream",
    "dev": "npm run build && concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "npm run start --workspace=@mj-forge/renderer",
    "dev:main": "wait-on http://localhost:4200 && NODE_ENV=development npm run start --workspace=@mj-forge/main",
    "start": "turbo run start",
    "watch": "turbo run watch",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,scss,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,scss,css,html}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "package": "npm run build && electron-builder --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:dir": "npm run build && electron-builder --dir --config electron-builder.yml",
    "prepare": "husky"
  },
  "main": "packages/main/dist/index.js",
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "concurrently": "^9.2.1",
    "electron-builder": "26.4.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.1",
    "syncpack": "^12.3.2",
    "ts-jest": "^29.4.6",
    "turbo": "^2.3.3",
    "typescript": "~5.4.5",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "@types/node": "^20.14.2",
    "typescript": "~5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,scss,css,html}": [
      "prettier --write"
    ]
  }
}
