{
  "name": "@mj-forge/main",
  "version": "1.0.0",
  "description": "Electron main process for MJ Forge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
