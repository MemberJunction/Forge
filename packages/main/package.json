    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@mj-forge/shared": "*",
    "dockerode": "^4.0.2",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0",
    "mssql": "^11.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/mssql": "^9.1.5",
    "@types/uuid": "^10.0.0",
    "electron": "^33.2.0",
    "typescript": "~5.4.5"
  }
}
